# Copy this file to `.env` in the project root and fill in your own values.
# Variable names mirror backend/app/config.py (Settings). Non-secret values
# below are the same defaults the app already falls back to.

# --- Neo4j ---
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_MAX_CONNECTION_POOL_SIZE=10
NEO4J_MAX_CONNECTION_LIFETIME=3600

# --- Gemini / Vertex AI ---
GEMINI_API_KEY=your-gemini-api-key-here
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_BUILDER=gemini-2.5-flash
GEMINI_MODEL_GARDENER=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.95
GEMINI_MAX_OUTPUT_TOKENS=131072
GEMINI_REQUEST_TIMEOUT=90.0
GEMINI_MAX_RETRIES=2

# --- Embeddings / similarity ---
EMBEDDING_DIMENSIONS=768
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_CACHE_SIZE=512
EMBEDDING_SIMILARITY_FUNCTION=cosine
SIMILARITY_THRESHOLD=0.92
SIMILARITY_TOP_K=5
SIMILARITY_CHECK_ENABLED=true
TYPE_SIMILARITY_THRESHOLD=0.80

# --- Redis / agent scheduling ---
REDIS_URL=redis://localhost:6379
BUILDER_GARDENER_RATIO=5
# Seconds before a Builder chunk-processing task is cancelled (default 90).
BUILDER_TASK_TIMEOUT=90

# --- Dev/test switches (all default off) ---
# Set to 1 to stub Gemini LLM calls / embeddings (demo without an API key).
PLASTICFLOWER_FAKE_LLM=0
PLASTICFLOWER_FAKE_EMBEDDINGS=0
# Set to 1 to boot the backend without Neo4j (health check reports "skipped").
PLASTICFLOWER_SKIP_NEO4J=0
# Force IPv4 DNS resolution (Windows workaround for ~21s IPv6 fallback delays;
# applies to the backend and scripts/smoke_test.py).
# Default: ON on Windows, OFF elsewhere. Set to 1 to force on (any platform)
# or 0 to force off (opts out of the Windows default). Leave unset/blank to
# keep the platform default.
#PLASTICFLOWER_FORCE_IPV4=

# --- Agent enable flags ---
# Gate automatic Researcher dispatch from the Gardener scheduler (manual
# research via the API is always available).
RESEARCHER_ENABLED=true

# --- Tavily (Researcher agent web search) ---
TAVILY_API_KEY=your-tavily-api-key-here
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/

# --- Frontend (Next.js reads NEXT_PUBLIC_* at build/dev time; also honoured
# --- from frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8010
# Set to 1 to enable verbose per-event browser console logging (SSE/speech).
#NEXT_PUBLIC_DEBUG=0
# Base URL used by `npm run replay` (frontend/scripts/replayChunks.mjs);
# defaults to http://localhost:8010 when unset.
#API_BASE_URL=http://localhost:8010
